---
interface Props {
  name: string;
  class?: string;
}

import type { AstroComponentFactory } from "astro/runtime/server/index.js";
import FallbackCodeIcon from "./icons/social/FallbackCodeIcon.astro";
import GithubIcon from "./icons/social/GithubIcon.astro";
import GoodreadsIcon from "./icons/social/GoodreadsIcon.astro";
import InstagramIcon from "./icons/social/InstagramIcon.astro";
import LinkedinIcon from "./icons/social/LinkedinIcon.astro";

const { name, class: className } = Astro.props;

const ICON_COMPONENTS: Record<string, AstroComponentFactory> = {
  github: GithubIcon,
  linkedin: LinkedinIcon,
  instagram: InstagramIcon,
  goodreads: GoodreadsIcon,
};

const Icon = ICON_COMPONENTS[name] ?? FallbackCodeIcon;
---

<Icon class={className} />
