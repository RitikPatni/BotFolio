---
import ExpandIcon from "./icons/ExpandIcon.astro";
import InfoIcon from "./icons/InfoIcon.astro";
import CloseIcon from "./icons/CloseIcon.astro";
import ChevronLeftIcon from "./icons/ChevronLeftIcon.astro";
import ChevronRightIcon from "./icons/ChevronRightIcon.astro";
import ImageIcon from "./icons/ImageIcon.astro";
import CalendarIcon from "./icons/CalendarIcon.astro";
import StackIcon from "./icons/StackIcon.astro";

interface Props {
  name:
    | "expand"
    | "info"
    | "close"
    | "chevron-left"
    | "chevron-right"
    | "image"
    | "calendar"
    | "stack";
  class?: string;
}

const { name, class: className } = Astro.props;

const ICON_COMPONENTS = {
  expand: ExpandIcon,
  info: InfoIcon,
  close: CloseIcon,
  "chevron-left": ChevronLeftIcon,
  "chevron-right": ChevronRightIcon,
  image: ImageIcon,
  calendar: CalendarIcon,
  stack: StackIcon,
};

const isKnownIcon = (value: string): value is keyof typeof ICON_COMPONENTS =>
  Object.prototype.hasOwnProperty.call(ICON_COMPONENTS, value);

const Icon = isKnownIcon(name) ? ICON_COMPONENTS[name] : ImageIcon;
---

<Icon class={className} />
