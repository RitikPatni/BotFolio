---
import ExpandIcon from "./icons/ExpandIcon.astro";
import InfoIcon from "./icons/InfoIcon.astro";
import CloseIcon from "./icons/CloseIcon.astro";
import ChevronLeftIcon from "./icons/ChevronLeftIcon.astro";
import ChevronRightIcon from "./icons/ChevronRightIcon.astro";
import ImageIcon from "./icons/ImageIcon.astro";
import CalendarIcon from "./icons/CalendarIcon.astro";
import StackIcon from "./icons/StackIcon.astro";

interface Props {
  name:
    | "expand"
    | "info"
    | "close"
    | "chevron-left"
    | "chevron-right"
    | "image"
    | "calendar"
    | "stack";
  class?: string;
}

const { name, class: className } = Astro.props;
---

{
  name === "expand" ? (
    <ExpandIcon class={className} />
  ) : name === "info" ? (
    <InfoIcon class={className} />
  ) : name === "close" ? (
    <CloseIcon class={className} />
  ) : name === "chevron-left" ? (
    <ChevronLeftIcon class={className} />
  ) : name === "chevron-right" ? (
    <ChevronRightIcon class={className} />
  ) : name === "calendar" ? (
    <CalendarIcon class={className} />
  ) : name === "stack" ? (
    <StackIcon class={className} />
  ) : (
    <ImageIcon class={className} />
  )
}
