---
import '../../styles/global.scss';
import './BaseLayout.scss';
import { SITE_CONFIG } from '../../config/site';
import SocialIcon from '../../components/SocialIcon.astro';

interface Props {
  title: string;
  description?: string;
  path?: string;
}

const { title, description = SITE_CONFIG.defaultDescription, path = '/' } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/newsletter', label: 'Newsletter' },
  { href: '/uses', label: 'Uses' },
  { href: '/library', label: 'Library' },
  { href: '/photography', label: 'Photography' },
  { href: '/contact', label: 'Contact' }
];

const socials = SITE_CONFIG.socials;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-light-32x32.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-dark-32x32.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-light-16x16.png" media="(prefers-color-scheme: light)" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-dark-16x16.png" media="(prefers-color-scheme: dark)" />
    <link rel="icon" type="image/x-icon" href="/favicon-light.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon-light.png" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title={SITE_CONFIG.rssTitle} href="/rss.xml" />
  </head>
  <body>
    <div class="base-layout">
      <a class="base-layout__skip-link" href="#main-content">Skip to content</a>
      <header class="base-layout__header">
        <div class="base-layout__container">
          <div class="base-layout__nav">
            <a class="base-layout__brand" href="/" aria-label="Go to homepage"><strong>{SITE_CONFIG.personName}</strong></a>
          </div>
          <nav class="base-layout__links" aria-label="Main navigation">
            {nav.map((item) => (
              <a
                href={item.href}
                class={`base-layout__link ${path === item.href ? 'base-layout__link--active' : ''}`}
                aria-current={path === item.href ? 'page' : undefined}
              >
                {item.label}
              </a>
            ))}
          </nav>
        </div>
      </header>

      <main id="main-content" class="base-layout__container base-layout__main">
        <slot />
      </main>

      <footer class="base-layout__footer">
        <div class="base-layout__container base-layout__footer-content">
          <p class="base-layout__footer-copy">© {new Date().getFullYear()} {SITE_CONFIG.personName} · Built with Astro.</p>
          <nav class="base-layout__socials" aria-label="Social links">
            {socials.map((social) => (
              <a href={social.href} class="base-layout__social-link" target="_blank" rel="noreferrer noopener">
                <SocialIcon name={social.icon} class="base-layout__social-icon" />
                {social.label}
              </a>
            ))}
          </nav>
        </div>
      </footer>

      <button
        class="base-layout__theme-fab"
        type="button"
        id="themeFab"
        aria-label="Toggle light and dark theme"
        title="Toggle theme"
      >
        <span aria-hidden="true">◐</span>
      </button>
    </div>

    <script>
      import { animate, stagger } from 'motion';

      const root = document.documentElement;
      const storageKey = 'rp-theme';
      const apply = (theme) => {
        root.setAttribute('data-theme', theme);
      };
      const saved = localStorage.getItem(storageKey);
      if (saved === 'light' || saved === 'dark') apply(saved);

      const toggleButton = document.getElementById('themeFab');
      toggleButton?.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        const next = current === 'light' ? 'dark' : 'light';
        apply(next);
        localStorage.setItem(storageKey, next);
      });

      const revealTargets = document.querySelectorAll('.motion-reveal');
      if (revealTargets.length > 0) {
        animate(
          revealTargets,
          { opacity: [0, 1], transform: ['translateY(8px)', 'translateY(0px)'] },
          { duration: 0.35, easing: 'ease-out', delay: stagger(0.06) }
        );
      }
    </script>
  </body>
</html>
