---
import "../../styles/global.scss";
import "./BaseLayout.scss";
import { SITE_CONFIG, NAV_LINKS_BY_PERSONA } from "../../config/site";
import { ViewTransitions } from "astro:transitions";
import SocialIcon from "../../components/SocialIcon.astro";

interface Props {
  title: string;
  description?: string;
  path?: string;
}

const {
  title,
  description = SITE_CONFIG.defaultDescription,
  path = "/",
} = Astro.props;

const socials = SITE_CONFIG.socials;
const navSets = NAV_LINKS_BY_PERSONA;
---

<!doctype html>
<html
  lang="en"
  data-theme="dark"
  data-persona="studio"
  transition:name="page-root"
  transition:animate="none"
>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <script is:inline>
      (() => {
        const THEME_STORAGE_KEY = "rp-theme";
        const PERSONA_STORAGE_KEY = "rp-persona";

        const applySavedTheme = () => {
          try {
            const savedTheme = localStorage.getItem(THEME_STORAGE_KEY);

            if (savedTheme === "light" || savedTheme === "dark") {
              document.documentElement.setAttribute("data-theme", savedTheme);
            }
          } catch {
            // Ignore storage access errors; layout falls back to default theme.
          }
        };

        const applySavedPersona = () => {
          try {
            const savedPersona = localStorage.getItem(PERSONA_STORAGE_KEY);
            const persona = savedPersona === "field" ? "field" : "studio";
            document.documentElement.setAttribute("data-persona", persona);
          } catch {
            document.documentElement.setAttribute("data-persona", "studio");
          }
        };

        applySavedTheme();
        applySavedPersona();

        try {
          if (sessionStorage.getItem("rp-persona-transition") === "1") {
            document.documentElement.classList.add("is-persona-entering");
          }
        } catch {
          // Ignore storage access errors; entry animation is optional.
        }

        if (!window.__rpThemeSwapHookBound) {
          document.addEventListener("astro:after-swap", applySavedTheme);
          document.addEventListener("astro:after-swap", applySavedPersona);
          window.__rpThemeSwapHookBound = true;
        }
      })();
    </script>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=IBM+Plex+Serif:wght@400;500;600;700&family=Inter:wght@400;500;600;700;800&display=swap"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon-light-32x32.png"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="32x32"
      href="/favicon-dark-32x32.png"
      media="(prefers-color-scheme: dark)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon-light-16x16.png"
      media="(prefers-color-scheme: light)"
    />
    <link
      rel="icon"
      type="image/png"
      sizes="16x16"
      href="/favicon-dark-16x16.png"
      media="(prefers-color-scheme: dark)"
    />
    <link rel="icon" type="image/x-icon" href="/favicon-light.ico" />
    <link
      rel="apple-touch-icon"
      sizes="180x180"
      href="/apple-touch-icon-light.png"
    />
    <title>{title}</title>
    <meta name="description" content={description} />
    <meta name="color-scheme" content="dark light" />
    <meta
      name="theme-color"
      content="#f8f7f4"
      media="(prefers-color-scheme: light)"
    />
    <meta
      name="theme-color"
      content="#111111"
      media="(prefers-color-scheme: dark)"
    />
    <ViewTransitions />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={SITE_CONFIG.rssTitle}
      href="/rss.xml"
    />
  </head>
  <body>
    <div class="base-layout" data-page-shell>
      <a class="base-layout__skip-link" href="#main-content">Skip to content</a>
      <header class="base-layout__header">
        <div class="base-layout__container">
          <div class="base-layout__topbar">
            <div class="base-layout__nav">
              <a
                class="base-layout__brand"
                href="/coding"
                aria-label="Go to profile home"
                data-persona-brand
              >
                <strong>{SITE_CONFIG.personName}</strong>
              </a>
            </div>
            <button
              class="base-layout__persona-toggle"
              type="button"
              data-persona-toggle
              aria-label="Switch profile lens"
              title="Switch profile lens"
              aria-pressed="false"
            >
              <span
                class="base-layout__persona-toggle-track"
                aria-hidden="true"
              >
                <span
                  class="base-layout__persona-toggle-state base-layout__persona-toggle-state--studio"
                  >⌨</span
                >
                <span
                  class="base-layout__persona-toggle-state base-layout__persona-toggle-state--field"
                  >📷</span
                >
                <span class="base-layout__persona-toggle-thumb">
                  <span class="base-layout__persona-toggle-thumb-icon">⌨</span>
                </span>
              </span>
            </button>
          </div>
          <div class="base-layout__menu-row">
            <nav
              class="base-layout__links"
              aria-label="Main navigation"
              data-persona-nav="studio"
            >
              {
                navSets.studio.map((item) => (
                  <a
                    href={item.href}
                    class={`base-layout__link ${path === item.href ? "base-layout__link--active" : ""}`}
                    aria-current={path === item.href ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>
            <nav
              class="base-layout__links"
              aria-label="Main navigation"
              data-persona-nav="field"
            >
              {
                navSets.field.map((item) => (
                  <a
                    href={item.href}
                    class={`base-layout__link ${path === item.href ? "base-layout__link--active" : ""}`}
                    aria-current={path === item.href ? "page" : undefined}
                  >
                    {item.label}
                  </a>
                ))
              }
            </nav>
          </div>
        </div>
      </header>

      <main
        id="main-content"
        class="base-layout__container base-layout__main"
        transition:name="page-content"
        transition:animate="fade"
      >
        <slot />
      </main>

      <footer class="base-layout__footer">
        <div class="base-layout__container base-layout__footer-content">
          <p class="base-layout__footer-copy">
            © {new Date().getFullYear()}
            {SITE_CONFIG.personName} · Built with Astro.
          </p>
          <nav class="base-layout__socials" aria-label="Social links">
            {
              socials.map((social) => (
                <a
                  href={social.href}
                  class="base-layout__social-link"
                  target="_blank"
                  rel="noreferrer noopener"
                >
                  <SocialIcon
                    name={social.icon}
                    class="base-layout__social-icon"
                  />
                  {social.label}
                </a>
              ))
            }
          </nav>
        </div>
      </footer>

      <button
        class="base-layout__theme-fab"
        type="button"
        id="themeFab"
        aria-label="Toggle light and dark theme"
        title="Toggle theme"
      >
        <span aria-hidden="true">◐</span>
      </button>
    </div>

    <script>
      import { initBaseLayoutClient } from "../../utils/layout/baseLayout.client";

      initBaseLayoutClient({ animateReveals: true });
      document.addEventListener("DOMContentLoaded", () => {
        initBaseLayoutClient({ animateReveals: true });
      });
      document.addEventListener("astro:page-load", () => {
        initBaseLayoutClient({ animateReveals: false });
      });
    </script>
  </body>
</html>
