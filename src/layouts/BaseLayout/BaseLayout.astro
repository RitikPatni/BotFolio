---
import '../../styles/global.scss';
import './BaseLayout.scss';

interface Props {
  title: string;
  description?: string;
  path?: string;
}

const { title, description = 'Ritik Patni — frontend developer and wildlife/macro photographer.', path = '/' } = Astro.props;

const nav = [
  { href: '/', label: 'Home' },
  { href: '/about', label: 'About' },
  { href: '/blog', label: 'Blog' },
  { href: '/newsletter', label: 'Newsletter' },
  { href: '/uses', label: 'Uses' },
  { href: '/library', label: 'Library' },
  { href: '/photography', label: 'Photography' },
  { href: '/contact', label: 'Contact' }
];
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="alternate" type="application/rss+xml" title="Ritik Patni RSS Feed" href="/rss.xml" />
  </head>
  <body>
    <div class="base-layout">
      <a class="base-layout__skip-link" href="#main-content">Skip to content</a>
      <header class="base-layout__header">
        <div class="base-layout__container base-layout__nav">
          <a class="base-layout__brand" href="/" aria-label="Go to homepage"><strong>Ritik Patni</strong></a>
          <nav class="base-layout__links" aria-label="Main navigation">
          {nav.map((item) => (
            <a
              href={item.href}
              class={`base-layout__link ${path === item.href ? 'base-layout__link--active' : ''}`}
              aria-current={path === item.href ? 'page' : undefined}
            >
              {item.label}
            </a>
          ))}
            <button class="base-layout__theme-toggle" type="button" id="themeToggle" aria-label="Toggle light and dark theme">Theme</button>
          </nav>
        </div>
      </header>

      <main id="main-content" class="base-layout__container base-layout__main">
        <slot />
      </main>

      <footer class="base-layout__footer">
        <div class="base-layout__container base-layout__footer-content">© {new Date().getFullYear()} Ritik Patni · Built with Astro.</div>
      </footer>
    </div>

    <script is:inline>
      const root = document.documentElement;
      const storageKey = 'rp-theme';
      const apply = (theme) => {
        root.setAttribute('data-theme', theme);
      };
      const saved = localStorage.getItem(storageKey);
      if (saved === 'light' || saved === 'dark') apply(saved);

      document.getElementById('themeToggle')?.addEventListener('click', () => {
        const current = root.getAttribute('data-theme') === 'light' ? 'light' : 'dark';
        const next = current === 'light' ? 'dark' : 'light';
        apply(next);
        localStorage.setItem(storageKey, next);
      });
    </script>
  </body>
</html>
