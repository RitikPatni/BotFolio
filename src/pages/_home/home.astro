---
import BaseLayout from "../../layouts/BaseLayout/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDisplayDate } from "../../utils/date";
import "./_home.scss";

const posts = (await getCollection("blog"))
  .filter((post) => !post.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime())
  .slice(0, 3)
  .map((post) => ({
    slug: post.slug,
    title: post.data.title,
    description: post.data.description,
    date: post.data.date,
  }));
---

<BaseLayout
  title="Ritik Patni — Frontend developer & wildlife/macro photographer"
  description="I build thoughtful web experiences and document nature up close."
  path="/"
>
  <div class="index primitive-stack">
    <!--
    Content provenance (Obsidian):
    - legacy-vault/🧔 private/Jobs/Cover Letter 1.md
    - legacy-vault/🧔 private/Jobs/Cover Letter 2.md
  -->
    <section class="index__hero primitive-section motion-reveal">
      <div class="index__hero-content">
        <h1 class="index__title">
          Thoughtful interfaces. Patient field notes. One place.
        </h1>
        <p class="index__lead">
          I design and build web experiences with a systems mindset, then switch
          lenses to document wildlife and macro moments. This space blends both
          disciplines into one evolving archive.
        </p>
        <p>
          <a class="index__inline-link primitive-link" href="/blog"
            >Explore engineering notes</a
          >
        </p>
      </div>
    </section>

    <section class="primitive-section motion-reveal">
      <h2 class="index__section-title">Latest blog posts</h2>
      {
        posts.length === 0 ? (
          <article class="index__card primitive-surface">
            <p>No blog posts yet.</p>
          </article>
        ) : (
          <div class="index__list">
            {posts.map((post) => (
              <article class="index__item primitive-surface">
                <h3 class="index__item-title">
                  <a href={`/blog/${post.slug}`}>{post.title}</a>
                </h3>
                <p class="index__meta index__meta--spaced">
                  {formatDisplayDate(post.date)}
                </p>
                <p class="index__description">{post.description}</p>
              </article>
            ))}
          </div>
        )
      }
      <p>
        <a class="index__inline-link primitive-link" href="/blog"
          >View all blog posts</a
        >
      </p>
    </section>
  </div>
</BaseLayout>
