---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="Uses — Ritik Patni" path="/uses">
  <section class="hero">
    <h1>Uses</h1>
    <p>Hardware, software, and tools I use for development and photography.</p>
  </section>

  <div class="grid two">
    <section class="card">
      <h3>Computers</h3>
      <ul>
        <li>Personal: MacBook Pro (2021) — Apple M1 Pro, 32GB RAM</li>
        <li>Office: MacBook Pro (2025) — Apple M4 Pro, 24GB RAM</li>
      </ul>
    </section>

    <section class="card">
      <h3>Software</h3>
      <ul>
        <li>Adobe Lightroom Classic</li>
        <li>Visual Studio Code</li>
        <li>Cursor</li>
        <li>Hermes Agent</li>
        <li>Hyper</li>
        <li>MonoLisa</li>
      </ul>
    </section>

    <section class="card">
      <h3>Camera bodies</h3>
      <ul>
        <li>Sony A6700</li>
        <li>Fujifilm X-T200</li>
      </ul>
    </section>

    <section class="card">
      <h3>Lenses</h3>
      <ul>
        <li>Sony FE 200-600mm F5.6-6.3 G OSS</li>
        <li>Tamron 90mm F2.8 Di III MACRO VXD (Model F072, Sony E)</li>
        <li>Sigma 30mm F1.4 DC DN | Contemporary (Sony E)</li>
        <li>Fujinon XF 70-300mm F4-5.6 R LM OIS WR</li>
        <li>Viltrox AF 56mm F1.4 XF</li>
      </ul>
    </section>
  </div>

  <section class="card" style="margin-top: 1rem;">
    <h3>Desk setup</h3>
    <ul>
      <li>Tofu65 keyboard</li>
      <li>Stack Overflow “The Key” keyboard</li>
      <li>Maja keyboard</li>
      <li>Logitech MX Master 3 (white)</li>
    </ul>
    <p class="post-meta">This page will evolve as setup changes.</p>
  </section>
</BaseLayout>
