---
import BaseLayout from "../../../layouts/BaseLayout/BaseLayout.astro";
import { getCollection } from "astro:content";
import { formatDisplayDate } from "../../../utils/date";

export async function getStaticPaths() {
  const items = await getCollection("highlights", ({ data }) => !data.draft);
  return items.map((item) => ({
    params: { slug: item.slug },
    props: { item },
  }));
}

const { item } = Astro.props;
const { Content } = await item.render();
import "./_slug.scss";
---

<BaseLayout
  title={`${item.data.title} — Highlights`}
  description={item.data.description}
  path="/library"
>
  <div class="slug">
    <article class="slug__hero slug__hero--compact">
      <p class="slug__meta">{formatDisplayDate(item.data.date)}</p>
      <h1 class="slug__title">{item.data.title}</h1>
      <p class="slug__lead">{item.data.description}</p>
    </article>

    <article class="slug__card">
      <div class="slug__content">
        <Content />
      </div>
    </article>
  </div>
</BaseLayout>
