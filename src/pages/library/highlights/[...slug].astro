---
import BaseLayout from '../../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

export async function getStaticPaths() {
  const items = await getCollection('highlights', ({ data }) => !data.draft);
  return items.map((item) => ({ params: { slug: item.slug }, props: { item } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---

<BaseLayout title={`${item.data.title} — Highlights`} description={item.data.description} path="/library">
  <article class="hero" style="padding-bottom: 0.8rem;">
    <p class="post-meta">{item.data.date.toISOString().slice(0, 10)}</p>
    <h1>{item.data.title}</h1>
    <p>{item.data.description}</p>
  </article>

  <article class="card">
    <Content />
  </article>
</BaseLayout>
