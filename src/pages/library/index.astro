---
import BaseLayout from "../../layouts/BaseLayout/BaseLayout.astro";
import { getCollection } from "astro:content";
import { BOOK_CATEGORIES } from "../../data/library";
import {
  extractCoverImage,
  getHighlightMeta,
  normalizeBookDescription,
} from "../../utils/library";
import { formatDisplayDate } from "../../utils/date";

const books = (await getCollection("books"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const highlights = (await getCollection("highlights"))
  .filter((item) => !item.data.draft)
  .sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getBookCategoryMeta = (item: (typeof books)[number]) => {
  const languageRaw = String(item.data.language || "")
    .toLowerCase()
    .trim();
  const language = languageRaw === "hindi" ? "hindi" : "english";

  const hasNonFictionGenre = item.data.genres.some(
    (genre) =>
      String(genre).toLowerCase().includes("non") &&
      String(genre).toLowerCase().includes("fiction"),
  );

  const textPool = `${item.data.description}\n${item.body}`.toLowerCase();
  const hasNonFictionTag =
    textPool.includes("#genre/non-fiction") ||
    textPool.includes("#genre/nonfiction");

  const genre =
    hasNonFictionGenre || hasNonFictionTag ? "non-fiction" : "fiction";

  return { genre, language };
};

const normalizeTitleKey = (value: string) =>
  value
    .toLowerCase()
    .replace(/^\(book\)\s*/g, "")
    .replace(/[^\p{L}\p{N}]+/gu, " ")
    .trim();

const stripBookPrefix = (value: string) =>
  value.replace(/^\(book\)\s*/i, "").trim();

const parsedHighlights = highlights.map((item) => ({
  ...item,
  meta: getHighlightMeta(item),
}));

const bookHighlights = parsedHighlights.filter(
  (item) => item.meta.sourceType === "readwise-books",
);

const nonBookHighlights = parsedHighlights.filter(
  (item) => item.meta.sourceType !== "readwise-books",
);

const recentHighlights = nonBookHighlights.slice(0, 24);

const bookHighlightByTitle = new Map<string, (typeof bookHighlights)[number]>();
for (const item of bookHighlights) {
  const key = normalizeTitleKey(item.data.title);
  if (!key || bookHighlightByTitle.has(key)) {
    continue;
  }
  bookHighlightByTitle.set(key, item);
}

const usedBookHighlightSlugs = new Set<string>();

const booksWithNotes = books.map((item) => {
  const bookKey = normalizeTitleKey(item.data.title);
  let linkedHighlight = bookHighlightByTitle.get(bookKey) || null;

  if (!linkedHighlight && bookKey) {
    linkedHighlight =
      bookHighlights.find((candidate) => {
        if (usedBookHighlightSlugs.has(candidate.slug)) {
          return false;
        }

        const candidateKey = normalizeTitleKey(candidate.data.title);
        if (!candidateKey) {
          return false;
        }

        return candidateKey.includes(bookKey) || bookKey.includes(candidateKey);
      }) || null;
  }

  if (linkedHighlight) {
    usedBookHighlightSlugs.add(linkedHighlight.slug);
  }

  return {
    ...item,
    ...getBookCategoryMeta(item),
    normalizedDescription: normalizeBookDescription(item.data.description),
    coverImage: extractCoverImage(item.body),
    displayTitle: stripBookPrefix(item.data.title),
    linkedHighlight,
  };
});

const categoryCounts: Record<string, number> = {
  all: booksWithNotes.length,
  fiction: booksWithNotes.filter((item) => item.genre === "fiction").length,
  "non-fiction": booksWithNotes.filter((item) => item.genre === "non-fiction")
    .length,
  english: booksWithNotes.filter((item) => item.language === "english").length,
  hindi: booksWithNotes.filter((item) => item.language === "hindi").length,
  "with-notes": booksWithNotes.filter((item) => Boolean(item.linkedHighlight))
    .length,
};

const bookFilterCategories = [
  ...BOOK_CATEGORIES,
  { id: "with-notes", label: "With notes" },
] as const;

const defaultBookFilter =
  categoryCounts["with-notes"] > 0 ? "with-notes" : "all";

import "./_library.scss";
---

<BaseLayout title="Library — Ritik Patni" path="/library">
  <div class="library">
    <section class="library__hero">
      <h1 class="library__title">Library</h1>
      <p class="library__lead">Books and notes from the reading log.</p>
    </section>

    <div
      class="library__views"
      data-library-root
      data-default-book-filter={defaultBookFilter}
    >
      <section class="library__panel">
        <h2 class="library__section-title">Books</h2>

        <div
          class="library__tags library__tags--spaced"
          role="group"
          aria-label="Book categories"
        >
          {
            bookFilterCategories.map((category) => (
              <button
                type="button"
                class="library__tag library__tag-button"
                data-book-filter={category.id}
                aria-pressed={
                  category.id === defaultBookFilter ? "true" : "false"
                }
              >
                {category.label}
                <span class="library__tag-count">
                  ({categoryCounts[category.id]})
                </span>
              </button>
            ))
          }
        </div>

        {
          books.length === 0 ? (
            <article class="library__card">
              <p>No books yet.</p>
            </article>
          ) : (
            <div class="library__books-grid">
              {booksWithNotes.map((item) => (
                <article
                  class="library__item"
                  data-book-item
                  data-book-genre={item.genre}
                  data-book-language={item.language}
                  data-book-has-notes={item.linkedHighlight ? "true" : "false"}
                >
                  {item.coverImage ? (
                    <a
                      class="library__book-cover-link"
                      href={`/library/books/${item.slug}`}
                    >
                      <img
                        class="library__book-cover"
                        src={item.coverImage}
                        alt={`${item.displayTitle} cover`}
                        loading="lazy"
                        decoding="async"
                      />
                    </a>
                  ) : null}

                  <h3 class="library__item-title">
                    <a href={`/library/books/${item.slug}`}>
                      {item.displayTitle}
                    </a>
                  </h3>
                  <div class="library__item-meta-block">
                    <p class="library__item-meta-primary">
                      {item.data.author || "Unknown author"}
                      {item.data.language ? ` · ${item.data.language}` : ""}
                    </p>
                    <p class="library__item-meta-secondary">
                      {formatDisplayDate(item.data.date)}
                      {item.data.published_year
                        ? ` · Published ${item.data.published_year}`
                        : ""}
                    </p>
                  </div>
                  {item.normalizedDescription ? (
                    <p class="library__description">
                      {item.normalizedDescription}
                    </p>
                  ) : null}

                  {item.linkedHighlight ? (
                    <p class="library__book-note">
                      <a
                        href={`/library/highlights/${item.linkedHighlight.slug}`}
                      >
                        Book notes
                      </a>
                    </p>
                  ) : null}
                </article>
              ))}
            </div>
          )
        }
      </section>

      <section class="library__panel">
        <h2 class="library__section-title">Notes</h2>
        <div class="library__notes-list">
          {
            nonBookHighlights.length === 0 ? (
              <article class="library__card">
                <p>No highlights yet.</p>
              </article>
            ) : (
              recentHighlights.map((item) => (
                <article class="library__note-item">
                  <h3 class="library__note-title">
                    <a href={`/library/highlights/${item.slug}`}>
                      {item.data.title}
                    </a>
                  </h3>
                  <p class="library__meta library__meta--spaced">
                    {formatDisplayDate(item.data.date)}
                    {" · "}
                    {item.meta.sourceLabel} ({item.meta.highlightCount})
                  </p>
                  <p class="library__note-meta">
                    {item.meta.author}
                    {item.meta.language === "hindi" ? " · Hindi" : " · English"}
                  </p>
                  {item.meta.preview ? (
                    <p class="library__note-preview">{item.meta.preview}</p>
                  ) : null}
                  {item.meta.sourceUrl ? (
                    <p class="library__note-linkline">
                      <a
                        href={item.meta.sourceUrl}
                        rel="noopener noreferrer"
                        target="_blank"
                      >
                        Open source
                      </a>
                    </p>
                  ) : null}
                </article>
              ))
            )
          }
        </div>
      </section>
    </div>
  </div>

  <script>
    // @ts-nocheck
    const initBookFilters = () => {
      const roots = document.querySelectorAll("[data-library-root]");

      roots.forEach((root) => {
        if (root.dataset.bookFiltersBound === "true") {
          return;
        }
        root.dataset.bookFiltersBound = "true";

        const filterButtons = Array.from(
          root.querySelectorAll("[data-book-filter]"),
        );
        const bookItems = Array.from(root.querySelectorAll("[data-book-item]"));

        if (!filterButtons.length || !bookItems.length) {
          return;
        }

        const matchesCategory = (item, category) => {
          if (category === "all") {
            return true;
          }

          if (category === "fiction" || category === "non-fiction") {
            return item.dataset.bookGenre === category;
          }

          if (category === "english" || category === "hindi") {
            return item.dataset.bookLanguage === category;
          }

          if (category === "with-notes") {
            return item.dataset.bookHasNotes === "true";
          }

          return true;
        };

        const applyFilter = (category) => {
          filterButtons.forEach((button) => {
            button.setAttribute(
              "aria-pressed",
              String(button.dataset.bookFilter === category),
            );
          });

          bookItems.forEach((item) => {
            const visible = matchesCategory(item, category);
            item.toggleAttribute("hidden", !visible);
          });
        };

        root.addEventListener("click", (event) => {
          const target = event.target;
          if (!(target instanceof Element)) {
            return;
          }

          const filterButton = target.closest("[data-book-filter]");
          if (!filterButton || !root.contains(filterButton)) {
            return;
          }

          applyFilter(filterButton.dataset.bookFilter || "all");
        });

        applyFilter(root.dataset.defaultBookFilter || "all");
      });
    };

    initBookFilters();
    document.addEventListener("DOMContentLoaded", initBookFilters);
    document.addEventListener("astro:page-load", initBookFilters);
  </script>
</BaseLayout>
