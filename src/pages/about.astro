---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout title="About — Ritik Patni" path="/about">
  <section class="hero">
    <h1>About</h1>
    <p>
      I’m Ritik Patni — a frontend-focused builder and photographer.
      I care about clean user experience, readable architecture, and reliable systems.
    </p>
  </section>

  <article class="card">
    <p>
      On the photography side, I focus on wildlife and macro moments, with occasional travel and
      landscape work. I like documenting details people usually miss.
    </p>
    <p>
      This site is where both tracks live together: what I build, what I learn, and what I see.
    </p>
  </article>
</BaseLayout>
